# Development Dockerfile สำหรับ Bun
FROM oven/bun:1-alpine

WORKDIR /app

# Install curl for healthcheck
RUN apk add --no-cache curl

# Copy package.json
COPY package.json ./

# **CRITICAL FIX FOR SWC NATIVE BINARY ON DOCKER/ALPINE**
RUN bun install

# Copy source code (แต่ไม่ใช้ package-lock.json หรือ bun.lock ภายใน container)
COPY . .
RUN rm -f package-lock.json bun.lockb bun.lock

# Expose port
EXPOSE 3000

# Set environment to development
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV WATCHPACK_POLLING=true
ENV BUN_SILENCE_ASYNC_HOOKS_WARNING=1

# Run development server with optimizations
CMD ["bun", "dev", "--turbo"]
