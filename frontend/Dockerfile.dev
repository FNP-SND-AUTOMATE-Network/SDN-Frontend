# Development Dockerfile สำหรับ Bun
FROM oven/bun:1-alpine

WORKDIR /app

# Install curl for healthcheck
RUN apk add --no-cache curl

# Copy package files first for better caching
COPY package.json bun.lock ./

# Install all dependencies (including devDependencies)
RUN bun install

# Bun doesn't auto-install Next.js optional SWC binaries for Alpine ARM64
# Install them explicitly to prevent "Failed to load SWC binary" error
RUN bun add @next/swc-linux-arm64-musl @next/swc-linux-arm64-gnu 2>/dev/null || true

# Copy source code (แต่ไม่ใช้ package-lock.json ภายใน container)
COPY . .
# ลบ package-lock.json เพื่อไม่ให้ Next.js เข้าใจผิดว่าใช้ npm
RUN rm -f package-lock.json

# Expose port
EXPOSE 3000

# Set environment to development
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV WATCHPACK_POLLING=true
ENV BUN_SILENCE_ASYNC_HOOKS_WARNING=1

# Run development server with optimizations
CMD ["bun", "dev", "--turbo"]
